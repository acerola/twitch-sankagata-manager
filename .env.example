# Twitch Sankagata Manager — environment variables
# Copy to .env at repo root and fill real values. .env is gitignored.
# src-tauri/build.rs auto-loads ../.env via dotenvy; shell-exported vars
# override file values.

# ─── Required for production builds ───────────────────────────────────────────
# Twitch application client ID (public, device-code flow — no secret needed).
# Register at https://dev.twitch.tv/console/apps
# Read at compile time by src-tauri/build.rs; falls back to DEV_PLACEHOLDER_CLIENT_ID
# when unset so `bun run tauri dev` still builds.
TWITCH_CLIENT_ID=

# ─── CI / release signing (GitHub Actions secrets, not local .env) ────────────
# Generated via: bun run tauri signer generate -w ~/.tauri/twitch-sankagata.key
# Paste the PRIVATE key contents (not the path) into the GitHub secret.
TAURI_SIGNING_PRIVATE_KEY=

# Password for the signing key, if you set one during generation. Leave empty otherwise.
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# ─── Optional dev overrides ───────────────────────────────────────────────────
# Host Vite binds to for mobile/LAN device testing. Unset = localhost.
# TAURI_DEV_HOST=192.168.1.42

# ─── Twitch mock server (for local testing without real Twitch) ───────────────
# https://github.com/twitchdev/twitch-cli
#
#   twitch mock-api generate
#   twitch mock-api start            # helix on http://localhost:8080
#   twitch event websocket start-server --port 8081   # eventsub mock
#
# Then uncomment and rebuild (cargo clean if cached):
# TWITCH_API_BASE=http://localhost:8080
# TWITCH_ID_BASE=http://localhost:8080/auth
# TWITCH_EVENTSUB_URL=ws://localhost:8081/ws
#
# Defaults (leave commented for real Twitch):
#   TWITCH_API_BASE=https://api.twitch.tv
#   TWITCH_ID_BASE=https://id.twitch.tv
#   TWITCH_EVENTSUB_URL=wss://eventsub.wss.twitch.tv/ws
